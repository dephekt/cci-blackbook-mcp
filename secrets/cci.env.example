# Copy to secrets/cci.env:   cp secrets/cci.env.example secrets/cci.env
# (secrets/cci.env is gitignored — never commit real values.)

# Bearer token MCP clients must send. The placeholder is fine for localhost-only
# testing; generate a real one for any exposed deployment:  openssl rand -hex 32
CCI_BLACKBOOK_MCP_TOKEN=dev-local-token-change-me

# --- Voyage backend (real retrieval quality) ---
# Get a key at https://www.voyageai.com/. Leave blank to run the offline "stub"
# backend instead (start with CCI_EMBEDDING_BACKEND=stub — no key needed).
VOYAGE_API_KEY=

# Voyage retains and may train on submitted data BY DEFAULT. Opt out (one-way) in
# the Voyage dashboard, then set this to true to allow a real ingest of your PDF.
# Not required for the stub backend.
CCI_VOYAGE_RETENTION_CONFIRMED=false
